#!/bin/sh

#
# Gradle Wrapper 실행 스크립트 (Unix/macOS용)
#

##############################################################################
#
#  이 스크립트는 POSIX 호환 셸(sh, bash, zsh 등)에서 작동하도록 설계되었습니다.
#  주요 역할:
#  1. 적절한 Java 버전(JRE)이 있는지 확인
#  2. Gradle 실행에 필요한 환경 변수 설정
#  3. gradle-wrapper.jar를 실행하여 실제 Gradle 엔진 가동
#
##############################################################################

# APP_HOME 설정 시도 (스크립트가 위치한 디렉터리 찾기)
app_path=$0

# 심볼릭 링크 대응: 스크립트가 링크 파일인 경우 실제 원본 위치를 찾아갑니다.
while
    APP_HOME=${app_path%"${app_path##*/}"}
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in
      /*)   app_path=$link ;;
      *)    app_path=$APP_HOME$link ;;
    esac
done

APP_BASE_NAME=${0##*/}
# APP_HOME을 절대 경로로 변환
APP_HOME=$( cd -P "${APP_HOME:-./}" > /dev/null && printf '%s\n' "$PWD" ) || exit

# 사용 가능한 최대 파일 디스크립터 설정 (기본값: maximum)
MAX_FD=maximum

# 경고 메시지 출력 함수
warn () {
    echo "$*"
} >&2

# 에러 메시지 출력 후 종료 함수
die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# 운영체제(OS)별 환경 감지 (Cygwin, macOS 등)
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in
  CYGWIN* )         cygwin=true  ;;
  Darwin* )         darwin=true  ;;
  MSYS* | MINGW* )  msys=true    ;;
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH="\"\""

# JVM을 시작할 Java 실행 명령(java) 결정
if [ -n "$JAVA_HOME" ] ; then
    # 1. JAVA_HOME 환경 변수가 설정되어 있는 경우
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "에러: JAVA_HOME이 잘못된 디렉터리를 가리키고 있습니다: $JAVA_HOME"
    fi
else
    # 2. JAVA_HOME이 없으면 시스템 PATH에서 'java' 명령어를 찾음
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1
    then
        die "에러: JAVA_HOME이 설정되어 있지 않고 시스템 PATH에서 'java'를 찾을 수 없습니다."
    fi
fi

# 시스템의 최대 파일 디스크립터 제한을 늘림 (대규모 빌드 시 필요)
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in
      max*)
        MAX_FD=$( ulimit -H -n ) ||
            warn "최대 파일 디스크립터 한계치를 조회할 수 없습니다."
    esac
    case $MAX_FD in
      '' | soft) :;;
      *)
        ulimit -n "$MAX_FD" ||
            warn "최대 파일 디스크립터를 $MAX_FD로 설정할 수 없습니다."
    esac
fi

# Windows 호환 환경(Cygwin, MSYS)일 경우 경로 형식을 Windows 방식으로 변환
if "$cygwin" || "$msys" ; then
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )
    JAVACMD=$( cygpath --unix "$JAVACMD" )

    for arg do
        if
            case $arg in
              -*)   false ;;
              /?*)  t=${arg#/} t=/${t%%/*}
                    [ -e "$t" ] ;;
              *)    false ;;
            esac
        then
            arg=$( cygpath --path --ignore --mixed "$arg" )
        fi
        shift
        set -- "$@" "$arg"
    done
fi

# 기본 JVM 옵션 (메모리 설정 등)
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Java 실행 시 넘길 최종 인자값들을 구성 (stacking)
set -- \
        "-Dorg.gradle.appname=$APP_BASE_NAME" \
        -classpath "$CLASSPATH" \
        -jar "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
        "$@"

# 외부 환경 변수(JAVA_OPTS, GRADLE_OPTS)에서 보낸 옵션들을 추가로 파싱하여 병합
if ! command -v xargs >/dev/null 2>&1
then
    die "xargs 명령어가 없습니다. (인자 파싱에 필요)"
fi

eval "set -- $(
        printf '%s\n' "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" |
        xargs -n1 |
        sed ' s~[^-[:alnum:]+,./:=@_]~\\&~g; ' |
        tr '\n' ' '
    )" '"$@"'

# 최종적으로 Java 실행! (프로세스 제어권을 Java로 넘김)
exec "$JAVACMD" "$@"
